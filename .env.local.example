# Sanity (docs §11.5). Copy to .env.local and fill in real values.
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2025-01-01

# Hosted Studio build (`pnpm studio:deploy`) — mirror the values above; sanity
# deploy only inlines SANITY_STUDIO_* vars. Preview origin is where the hosted
# Studio's Presentation tool opens the site (production domain once deployed).
SANITY_STUDIO_PROJECT_ID=
SANITY_STUDIO_DATASET=production
SANITY_STUDIO_PREVIEW_ORIGIN=http://localhost:3000

# Server-only. Read token for draft mode / server fetches.
SANITY_API_READ_TOKEN=

# Server-only. Write token (Editor role); used by `pnpm seed` only.
SANITY_API_WRITE_TOKEN=

# Shared secret guarding the /api/revalidate webhook.
SANITY_REVALIDATE_SECRET=

# Supabase auth (booking.md §9.2). Dev project values until the vendor's
# arrive; the publishable key is public by design. Never a secret or
# service key, in env or code.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
